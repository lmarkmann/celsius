Output demo.gif

Set Width 1600
Set Height 1000
Set FontSize 14
Set Padding 0
Set Theme "OneHalfDark"

Type 'celsius -l "New York"'
Enter
Sleep 4s

# Show the keybindings overlay
Type "?"
Sleep 2s
Type "?"
Sleep 500ms

# Change location to Tokyo
Type "l"
Sleep 500ms
Type "Tokyo"
Sleep 500ms
Enter
Sleep 4s

# Change location to London
Type "l"
Sleep 500ms
Type "London"
Sleep 500ms
Enter
Sleep 4s

Type "q"
